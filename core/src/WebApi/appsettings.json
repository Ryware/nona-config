{
  "Storage": {
    "Type": "Auto",
    "Sqlite": {
      "DataSource": "/var/lib/nona/nona.db",
      "TimeoutSeconds": 30
    },
    "Libsql": {
      "TimeoutSeconds": 30,
      "ManagedPrimary": {
        "Enabled": true,
        "ExecutablePath": "/usr/local/bin/sqld",
        "DatabasePath": "/var/lib/nona/primary.db",
        "WorkingDirectory": "/var/lib/nona/",
        "HttpListenAddress": "0.0.0.0:9080",
        "LocalConnectUrl": "http://127.0.0.1:9080",
        "StartTimeoutSeconds": 30
      }
    }
  },
  "Sso": {
    "Google": {
      "ClientId": "",
      "JwksUri": "https://www.googleapis.com/oauth2/v3/certs",
      "Issuers": [
        "https://accounts.google.com",
        "accounts.google.com"
      ]
    },
    "Microsoft": {
      "ClientId": "",
      "TenantId": "common",
      "JwksUri": "https://login.microsoftonline.com/common/discovery/v2.0/keys"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Defaults": {
    "Environment": [
      "Production"
    ]
  },
  "ASPNETCORE": {
    "ENVIRONMENT": "Production",
    "URLS": "http://0.0.0.0:8080"
  }
}
